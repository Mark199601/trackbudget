# Cloudflare Pages — caching rules
# Force the browser/edge to always revalidate the service worker and app HTML
# so a new deploy is picked up immediately (no stale service worker serving old pages).

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate
